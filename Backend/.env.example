PORT=5000
APP_BASE_URL=http://localhost:5000

DATABASE_URL=postgresql://username:password@host/database?sslmode=require

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@example.com
MAIL_PASS=your-app-password
MAIL_FROM=Finance Management <your-email@example.com>

JWT_ACCESS_SECRET=replace_with_a_long_random_secret
JWT_REFRESH_SECRET=replace_with_a_different_long_random_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

OTP_EXPIRES_MINUTES=5
OTP_RESEND_COOLDOWN_SECONDS=60

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

AI_PROVIDER=gemini
AI_FALLBACK_ENABLED=true

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

AI_SQL_AGENT_ENABLED=false
AI_SQL_SERVICE_URL=http://127.0.0.1:8100
AI_SQL_SERVICE_SHARED_SECRET=replace_with_shared_secret
AI_SQL_SERVICE_TIMEOUT_MS=30000
AI_SQL_DATABASE_URL=postgresql://readonly_user:password@host/database?sslmode=require
AI_SQL_MAX_ROWS=20
